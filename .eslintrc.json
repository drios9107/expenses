{
  "env": {
      "browser": true,
      "es2021": true
  },
  "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "next/core-web-vitals"
  ],
  "parser": "espree",
  "parserOptions": {
      "ecmaVersion": 2020
  },
  "plugins": [
      "react"
  ],
  "rules": {
      "no-unused-vars": "off",
      "react/display-name": "off"
  }
}
